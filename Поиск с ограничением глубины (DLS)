def dls(graph, start, goal, limit):
    def recursive_dls(current, goal, path, depth):
        if current == goal:
            return path
        if depth == 0:
            return None
        for neighbor in graph[current]:
            if neighbor not in path:
                result = recursive_dls(neighbor, goal, path + [neighbor], depth - 1)
                if result is not None:
                    return result
        return None

    return recursive_dls(start, goal, [start], limit)

