import heapq

def a_star(graph, start, goal, heuristic):
    heap = [(heuristic[start], 0, start)]  # (f_score, g_score, node)
    came_from = {start: None}
    cost_so_far = {start: 0}
    
    while heap:
        f_score, g_score, current = heapq.heappop(heap)
        
        if current == goal:
            # Восстановить путь
            path = []
            while current is not None:
                path.append(current)
                current = came_from[current]
            return path[::-1]
        
        for neighbor in graph[current]:
            new_cost = g_score + 1  # Предполагаем стоимость ребра = 1
            if neighbor not in cost_so_far or new_cost < cost_so_far[neighbor]:
                cost_so_far[neighbor] = new_cost
                f_score_new = new_cost + heuristic[neighbor]
                heapq.heappush(heap, (f_score_new, new_cost, neighbor))
                came_from[neighbor] = current
                
    return None

# Пример эвристики для A*
heuristic_a_star = {'A': 5, 'B': 4, 'C': 3, 'D': 6, 'E': 2, 'F': 0}
print("A*:", a_star(graph, 'A', 'F', heuristic_a_star))
