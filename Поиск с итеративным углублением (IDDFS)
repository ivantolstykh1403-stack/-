def iddfs(graph, start, goal):
    def dls(current, goal, path, depth):
        if current == goal:
            return path
        if depth == 0:
            return None
        for neighbor in graph[current]:
            if neighbor not in path:
                result = dls(neighbor, goal, path + [neighbor], depth - 1)
                if result is not None:
                    return result
        return None

    depth = 0
    while True:
        result = dls(start, goal, [start], depth)
        if result is not None:
            return result
        depth += 1

